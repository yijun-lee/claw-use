# OpenClaw Dashboard Configuration

# Set to "true" to use mock data (default), "false" for real OpenClaw Gateway
OPENCLAW_MOCK=true

# OpenClaw Gateway URL (default: local gateway on port 18789)
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789

# OpenClaw Gateway Auth Token (required when OPENCLAW_MOCK=false)
OPENCLAW_GATEWAY_TOKEN=

# Agent ID for hook calls (default: main)
OPENCLAW_AGENT_ID=main

# MCP Server URL (auto-set in dev mode)
MCP_URL=http://localhost:3000
