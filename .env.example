# OpenClaw Dashboard Configuration

# Set to "true" to use mock data (default), "false" for real OpenClaw API
OPENCLAW_MOCK=true

# OpenClaw Gateway URL (required when OPENCLAW_MOCK=false)
OPENCLAW_API_URL=https://api.openclaw.io

# OpenClaw Auth Token (required when OPENCLAW_MOCK=false)
OPENCLAW_AUTH_TOKEN=

# MCP Server URL (auto-set in dev mode)
MCP_URL=http://localhost:3000
